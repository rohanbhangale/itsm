version: '3'

services:
  db:
    image: mysql:5.7
    container_name: snipeit_db
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root123
      MYSQL_DATABASE: snipeit
      MYSQL_USER: snipeit
      MYSQL_PASSWORD: snipeit123
    volumes:
      - db_data:/var/lib/mysql

  snipeit:
    image: snipe/snipe-it
    container_name: snipeit
    restart: always
    depends_on:
      - db
    ports:
      - "9090:80"
    environment:
      # REQUIRED: The missing key that caused the crash
      APP_KEY: base64:iMqxTwiIY+FjaGdgQupBZbpMHFEsDLj11TEmzLara0g=
      APP_URL: http://localhost:9090
      APP_DEBUG: "false"
      
      # DATABASE CONNECTION
      DB_CONNECTION: mysql
      DB_HOST: snipeit_db
      DB_PORT: 3306
      DB_DATABASE: snipeit
      DB_USERNAME: snipeit
      DB_PASSWORD: snipeit123
    volumes:
      - snipeit_data:/var/lib/snipeit

volumes:
  db_data:
  snipeit_data: